{
    // https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Agent (example-local.yaml)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/agent",
            "cwd": "${workspaceFolder}",
            "args": [
                "--config=${workspaceFolder}/config/example-local.yaml"
            ]
        },
        {
            "name": "Agent (custom --config)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/agent",
            "cwd": "${workspaceFolder}",
            "args": [
                "--config=${workspaceFolder}/config/config.yaml"
            ]
        },
        {
            "name": "Agent (default search paths)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/agent",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Dev gRPC server",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/dev-grpc-server",
            "cwd": "${workspaceFolder}",
            "args": [
                "-listen=127.0.0.1:50051",
                "-agent-control-demo=true",
                "-agent-control-demo-namespace=stage"
            ]
        },
        {
            "name": "Launch current package (fileDirname)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}"
        }
    ]
}
