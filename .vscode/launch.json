{
    // https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Agent (dev)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/agent",
            "cwd": "${workspaceFolder}",
            "args": [
                "--dev",
                "--config=${workspaceFolder}/config/example-local.yaml"
            ],
            "buildFlags": [
                "-ldflags",
                "-X github.com/kubexa/kubexa-agent/pkg/buildinfo.Version=dev -X github.com/kubexa/kubexa-agent/pkg/buildinfo.Commit=debug -X github.com/kubexa/kubexa-agent/pkg/buildinfo.BuildTime=local"
            ]
        },
        {
            "name": "Demo gateway (dev-grpc-server)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/dev-grpc-server",
            "cwd": "${workspaceFolder}",
            "args": [
                "-listen=127.0.0.1:50051"
            ]
        },
        {
            "name": "Agent (default search paths)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/agent",
            "cwd": "${workspaceFolder}"
        }
    ]
}
